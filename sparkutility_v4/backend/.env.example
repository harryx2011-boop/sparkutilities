PORT=2000

# Comma-separated list of allowed frontend origins.
# Add custom hostnames here after updating your system hosts file
# (add `127.0.0.1 sparkutilities.dev` to /etc/hosts on macOS/Linux,
# or %SystemRoot%\System32\drivers\etc\hosts on Windows).
CORS_ORIGINS=http://localhost:9000,http://sparkutilities.dev:9000

# Admin credentials. Required for the admin panel to be active.
# ADMIN_SESSION_SECRET MUST be at least 32 characters or the admin panel
# silently disables itself. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=replace-with-32+-character-random-hex-string
ADMIN_SESSION_TTL_HOURS=24

# Path to the yt-dlp binary used by the YouTube downloader.
# Leave unset to fall back to whatever `yt-dlp` resolves to on PATH.
# Examples:
#   YT_DLP_PATH=/usr/local/bin/yt-dlp
#   YT_DLP_PATH=C:\tools\yt-dlp.exe
# YT_DLP_PATH=

# Number of trusted proxies in front of this server. Default 0 = ignore
# X-Forwarded-For entirely.
#
# Local dev runs Vite's proxy in front of /api/*, which sets
# X-Forwarded-For. The rate limiter is explicitly configured (see
# RATE_LIMIT_VALIDATE in server.js) to ignore that header so the limiter
# falls back to the loopback socket address.
#
# Production checklist:
#   • Behind a reverse proxy on a trusted network → TRUST_PROXY=1
#   • Behind two proxies (e.g. CDN → load balancer → app) → TRUST_PROXY=2
#   • Direct exposure (no proxy in front of Node) → TRUST_PROXY=0
TRUST_PROXY=0
